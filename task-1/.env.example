# Supabase PostgreSQL connection string (pooler or direct; used by Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Supabase project (Data API + Auth client via supabase-js / @supabase/ssr)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
