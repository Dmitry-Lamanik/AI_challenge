# Supabase PostgreSQL connection string (pooler or direct; used by db:seed script)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Vite + supabase-js (anon key — safe for browser; keep secret keys server-side only)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
